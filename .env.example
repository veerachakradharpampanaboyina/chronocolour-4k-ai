# ============================================================
# ChronoColor 4K AI — Environment Configuration
# ============================================================
# Copy this file to .env and customize for your environment.
# ============================================================

# --- Application ---
APP_NAME=ChronoColor 4K AI
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# --- MongoDB ---
MONGODB_URI=mongodb://chronocolor:chronocolor_secret@mongodb:27017
MONGODB_DATABASE=chronocolor

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_DB=1
REDIS_PUBSUB_DB=2

# --- MinIO / S3 Storage ---
STORAGE_ENDPOINT=minio:9000
STORAGE_ACCESS_KEY=chronocolor_access
STORAGE_SECRET_KEY=chronocolor_secret_key
STORAGE_BUCKET_RAW=raw-videos
STORAGE_BUCKET_FRAMES=processed-frames
STORAGE_BUCKET_RESULTS=results
STORAGE_USE_SSL=false
STORAGE_REGION=us-east-1

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# --- GPU ---
GPU_DEVICE_IDS=0
GPU_MEMORY_FRACTION=0.9
GPU_ALLOW_GROWTH=true

# --- AI Models ---
MODELS_DIR=/app/models
DEFAULT_SUPERRES_MODEL=real_esrgan
DEFAULT_FACE_MODEL=codeformer
DEFAULT_COLORIZATION_MODEL=ddcolor
DEFAULT_RESTORATION_MODEL=nafnet
DEFAULT_FLOW_MODEL=raft

# --- Video Processing ---
MAX_VIDEO_SIZE_MB=5000
MAX_VIDEO_DURATION_SECONDS=600
FFMPEG_THREADS=4
OUTPUT_VIDEO_CODEC=libx265
OUTPUT_VIDEO_CRF=18
OUTPUT_VIDEO_PRESET=slow

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- Security ---
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
